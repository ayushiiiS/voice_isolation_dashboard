# MongoDB Atlas — replace with your cluster host (not cluster.mongodb.net placeholder)
MONGODB_URI=mongodb+srv://USER:PASSWORD@main-as1.8sh5xu.mongodb.net
MONGODB_DB=voice_isolation

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=1440

# Google Cloud Storage
# gcloud_cli = `gcloud auth login` user session (explicit, no service-account key)
# adc        = `gcloud auth application-default login`
GCS_USE_ADC=true
GCS_CREDENTIALS_SOURCE=gcloud_cli
BUCKET_NAME=cadence-audio
GCS_OBJECT_PREFIX=
REGION=asia-south1
# GOOGLE_CLOUD_PROJECT=your-gcp-project
API_BASE_URL=http://localhost:8000
PROCESSED_DIR=output/processed

# Hugging Face (pyannote Community-1)
HF_TOKEN=your_huggingface_token_here

# Redis / Celery (optional)
REDIS_URL=redis://redis:6379/0
USE_CELERY=false

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WORK_DIR=output/.work
KEEP_WORK_DIR=false

# Frontend (see frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Multi-provider streaming STT (simulated providers stay blank until API keys are set)
STT_ALLOW_SIMULATED=true
STT_DEFAULT_LANGUAGE=en-US
STT_LANGUAGE_DETECT=true
WHISPER_LID_MODEL=small
WHISPER_PRELOAD=true
STT_LANGUAGE_CONFIDENCE_THRESHOLD=0.80
STT_LANGUAGE_TOP_K=3
STT_TRANSCRIPT_MODE=consensus
STT_AUDIO_SOURCE=auto
STT_FEED_REALTIME=false
STT_PEAK_NORMALIZE=true
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-general
DEEPGRAM_ENDPOINTING_MS=100
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
# Use codemix for Hindi-English call recordings; transcribe for single-language audio
SARVAM_STT_MODE=transcribe
# When STT_MODE=transcribe, auto-switch to codemix for Hindi / multilingual detection
SARVAM_AUTO_CODEMIX=true
SARVAM_FLUSH_SIGNAL=true
SARVAM_HIGH_VAD=true
SARVAM_FLUSH_EVERY_CHUNKS=50
# unknown = auto-detect; hi-IN = pin Hindi; fixed = follow session language detection
SARVAM_LANGUAGE_CODE=unknown
